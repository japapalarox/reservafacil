# ============================================================
# ReservaFácil — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA suba o .env.local para o git!
# ============================================================

# --- Supabase ---
# Painel Supabase → Settings → API
REACT_APP_SUPABASE_URL=https://SEU_PROJETO.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua_anon_key_aqui

# --- Z-API (WhatsApp) ---
# https://app.z-api.io → sua instância → Token
REACT_APP_ZAPI_INSTANCE=SUA_INSTANCE_ID
REACT_APP_ZAPI_TOKEN=SEU_TOKEN_ZAPI
# Número que envia as mensagens (formato: 5514999999999)
REACT_APP_ZAPI_SENDER=55XXXXXXXXXXX
